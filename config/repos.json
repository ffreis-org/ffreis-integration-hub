      "component_type": "library",
      "package_name": "ml_crypto_rl",
      "onnx_boundary": {
        "role": "model",
        "description": "Exports actor-mean policy ONNX (dynamo=False): 11-feature observation → action scalar"
      },
      "checks": [
        "make lint",
        "make test"
      ]
